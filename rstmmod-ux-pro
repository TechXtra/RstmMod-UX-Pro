# =============================================
# ORIGINAL ENGINE LOGIC (TermuxVoid Framework)
# =============================================

check_dependencies() {
    echo -e "${YELLOW}[*] Checking system dependencies...${NC}"
    pkg update -y || echo -e "${RED}[!] Update skipped (Mirror issue)${NC}"
    for pkg in git curl fish starship jp2a eza; do
        if command -v $pkg &> /dev/null; then
            echo -e "${GREEN}[√] $pkg installed${NC}"
        else
            echo -e "${RED}[!] $pkg not found, installing...${NC}"
            pkg install $pkg -y
        fi
    done
}

set_fish_shell() {
    echo -e "${YELLOW}[*] Changing shell to Fish...${NC}"
    chsh -s fish
}

fetch_theme() {
    echo -e "${YELLOW}[*] Downloading theme repository...${NC}"
    rm -rf "$TMP_DIR"
    git clone "$REPO_URL" "$TMP_DIR"
}

customize_prompt() {
    echo -e "${YELLOW}[*] Configuring Starship prompt...${NC}"
    mkdir -p ~/.config/fish
    [ -f "$TMP_DIR/assets/starship.toml" ] && cp "$TMP_DIR/assets/starship.toml" ~/.config/starship.toml
    echo "starship init fish | source" > ~/.config/fish/config.fish
}

setup_banner() {
    echo -e "${YELLOW}[*] Setting up login banner...${NC}"
    mkdir -p ~/.termux
    cat << 'EOF' > ~/.termux/wlcm.sh
#!/data/data/com.termux/files/usr/bin/bash
clear
echo -e "\e[1;32m"
echo " ██████╗ ███████╗████████╗███╗   ███╗███╗   ███╗ ██████╗ ██████╗ "
echo " ██╔══██╗██╔════╝╚══██╔══╝████╗ ████║████╗ ████║██╔═══██╗██╔══██╗"
echo " ██████╔╝███████╗   ██║   ██╔████╔██║██╔████╔██║██║   ██║██║  ██║"
echo " ██╔══██╗╚════██║   ██║   ██║╚██╔╝██║██║╚██╔╝██║██║   ██║██║  ██║"
echo " ██║  ██║███████║   ██║   ██║ ╚═╝  ██║██║ ╚═╝  ██║╚██████╔╝██████╔╝"
echo " ╚═╝  ╚═╝╚══════╝   ╚═╝   ╚═╝      ╚═╝╚═╝      ╚═╝ ╚═════╝ ╚═════╝"
echo -e "\e[1;36m        Welcome back to RstmMod-UX-Pro VIP!\e[0m"
echo ""
EOF
    chmod +x ~/.termux/wlcm.sh
    echo "bash ~/.termux/wlcm.sh" >> ~/.config/fish/config.fish
}

install_files() {
    echo -e "${YELLOW}[*] Installing configuration files...${NC}"
    [ -f "$TMP_DIR/assets/colors.properties" ] && cp "$TMP_DIR/assets/colors.properties" ~/.termux/colors.properties
    [ -f "$TMP_DIR/assets/font.ttf" ] && cp "$TMP_DIR/assets/font.ttf" ~/.termux/font.ttf
    termux-reload-settings
}

complete_installation() {
    echo -e "\n${GREEN}[√] Installation completed successfully!${NC}"
    echo -e "\n${RED}IMPORTANT:${NC}"
    echo -e "1. Fully close and reopen Termux"
    rm -rf "$TMP_DIR"
    read -p "Press Enter to exit..."
}

# =============================================
# EXECUTION FLOW
# =============================================
show_header
check_dependencies
set_fish_shell
fetch_theme
customize_prompt
setup_banner
install_files
complete_installation
