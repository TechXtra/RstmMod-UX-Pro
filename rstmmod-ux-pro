# =============================================
# FUNCTION: install_files
# =============================================
install_files() {
    echo -e "${CYAN}[*] Installing colors and fonts...${NC}"
    mkdir -p ~/.termux
    [ -f "$TMP_DIR/colors.properties" ] && cp "$TMP_DIR/colors.properties" ~/.termux/colors.properties
    [ -f "$TMP_DIR/font.ttf" ] && cp "$TMP_DIR/font.ttf" ~/.termux/font.ttf
    termux-reload-settings
}

# =============================================
