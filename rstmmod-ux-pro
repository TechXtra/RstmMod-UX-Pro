    echo -e "${GREEN}[‚úď] RstmMod-UX-Pro v5.0 Installed!${NC}"
    echo -e "${GREEN}============================================${NC}"
    echo -e "\n${RED}PLEASE RESTART TERMUX TO SEE THE MAGIC!${NC}"
    rm -rf "$TMP_DIR"
    read -p "$(echo -e "\n${CYAN}Press Enter to finish...${NC}")"
}

