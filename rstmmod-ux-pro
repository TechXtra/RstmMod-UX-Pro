#!/data/data/com.termux/files/usr/bin/bash

# =============================================
# RstmMod-UX-Pro VIP Edition - Version 5.0
# Developed by: TechXtra
# =============================================

# Colors
GREEN="\e[1;32m"
CYAN="\e[1;36m"
WHITE="\e[1;37m"
YELLOW="\e[1;33m"
RED="\e[1;31m"
NC="\e[0m" # No Color

# Variables
REPO_URL="https://github.com/TechXtra/RstmMod-UX-Pro"
TMP_DIR="$HOME/rstmmod_tmp"

# =============================================
# FUNCTION: show_header
# =============================================
show_header() {
    clear
    echo -e "${GREEN}"
    echo "  ____       _             __  __           _ "
    echo " |  _ \  ___| |_ _ __ ___ |  \/  | ___   __| |"
    echo " | |_) / __| __| '_ \` _ \| |\/| |/ _ \ / _\` |"
    echo " |  _ <\__ \ |_| | | | | | |  | | (_) | (_| |"
    echo " |_| \_\___/\__|_| |_| |_|_|  |_|\___/ \__,_|"
    echo -e "${CYAN}             Version: 5.0 (VIP Edition)${NC}"
    echo -e "${WHITE}--------------------------------------------------${NC}"
    echo -e "${YELLOW}  Join us on TG:     ${WHITE}RstmMod${NC}"
    echo -e "${YELLOW}  Join us on Github: ${WHITE}TechXtra${NC}"
    echo -e "${WHITE}--------------------------------------------------${NC}"
    echo ""
}

# =============================================
# FUNCTION: check_dependencies
# =============================================
check_dependencies() {
    echo -e "${CYAN}[*] Checking dependencies...${NC}"
    pkg update -y && pkg upgrade -y
    for pkg in git curl fish starship; do
        if ! command -v $pkg &> /dev/null; then
            echo -e "${YELLOW}[!] Installing $pkg...${NC}"
            pkg install $pkg -y
        fi
    done
}

# =============================================
# FUNCTION: set_fish_shell
# =============================================
set_fish_shell() {
    echo -e "${CYAN}[*] Configuring Fish shell...${NC}"
    chsh -s fish
}

# =============================================
# FUNCTION: fetch_theme
# =============================================
fetch_theme() {
    echo -e "${CYAN}[*] Downloading theme repository...${NC}"
    rm -rf "$TMP_DIR"
    git clone "$REPO_URL" "$TMP_DIR"
}

# =============================================
# FUNCTION: customize_prompt
# =============================================
customize_prompt() {
    echo -e "${CYAN}[*] Setting up Starship prompt...${NC}"
    mkdir -p ~/.config
    if [ -f "$TMP_DIR/starship.toml" ]; then
        cp "$TMP_DIR/starship.toml" ~/.config/starship.toml
    fi
    # Add starship to fish config
    mkdir -p ~/.config/fish
    echo "starship init fish | source" > ~/.config/fish/config.fish
}

# =============================================
# FUNCTION: setup_banner
# =============================================
setup_banner() {
    echo -e "${CYAN}[*] Setting up custom banner...${NC}"
    # This logic replicates the "RstmMod" banner on every login
    mkdir -p ~/.termux
    cat << EOF > ~/.termux/wlcm.sh
    echo -e "${GREEN}"
    echo "  ____       _             __  __           _ "
    echo " |  _ \  ___| |_ _ __ ___ |  \/  | ___   __| |"
    echo " | |_) / __| __| '_ \` _ \| |\/| |/ _ \ / _\` |"
    echo " |  _ <\__ \ |_| | | | | | |  | | (_) | (_| |"
    echo " |_| \_\___/\__|_| |_| |_|_|  |_|\___/ \__,_|"
    echo -e "${CYAN}       Welcome back to RstmMod-UX-Pro!${NC}"
    echo ""
EOF
    echo "bash ~/.termux/wlcm.sh" >> ~/.config/fish/config.fish
}

# =============================================
# FUNCTION: install_files
# =============================================
install_files() {
    echo -e "${CYAN}[*] Installing colors and fonts...${NC}"
    mkdir -p ~/.termux
    [ -f "$TMP_DIR/colors.properties" ] && cp "$TMP_DIR/colors.properties" ~/.termux/colors.properties
    [ -f "$TMP_DIR/font.ttf" ] && cp "$TMP_DIR/font.ttf" ~/.termux/font.ttf
    termux-reload-settings
}

# =============================================
# FUNCTION: cleanup
# =============================================
cleanup() {
    echo -e "${CYAN}[*] Cleaning up installation files...${NC}"
    rm -rf "$TMP_DIR"
}

# =============================================
# FUNCTION: complete_installation
# =============================================
complete_installation() {
    echo -e "\n${GREEN}============================================${NC}"
    echo -e "${GREEN}[✓] Installation completed successfully!${NC}"
    echo -e "${GREEN}============================================${NC}"

    echo -e "\n${RED}IMPORTANT:${NC}"
    echo -e "1. Fully close the Termux app"
    echo -e "2. Reopen Termux to apply changes\n"

    echo -e "${YELLOW}Notes:${NC}"
    echo -e "- Default shell changed to Fish"
    echo -e "- Starship prompt configured"
    echo -e "- Color scheme and font installed"
    echo -e "- Version 5.0 VIP Features active"

    cleanup
    read -p "$(echo -e "\n${CYAN}Press Enter to exit...${NC}")"
}

# =============================================
# MAIN EXECUTION FLOW
# =============================================
show_header
check_dependencies
set_fish_shell
fetch_theme
customize_prompt
setup_banner
install_files
complete_installation
