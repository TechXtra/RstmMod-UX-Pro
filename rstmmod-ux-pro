# =============================================
# NEW: Matrix Animation Logic
# =============================================
start_matrix_loop() {
    echo -e "${CYAN}[*] Starting 10-second Matrix Loop... (CTRL+C to Stop)${NC}"
    while true; do
        cmatrix -as -u 10 & 
        PID=$!
        sleep 3
        kill $PID
        sleep 10
    done
}

# Original Tools (Preserved)
optimize_system() {
    echo -e "${YELLOW}[*] Cleaning and Optimizing Termux...${NC}"
    pkg update -y && pkg upgrade -y
    pkg autoclean && pkg autoremove
    termux-setup-storage
}

install_tools() {
    echo -e "${YELLOW}[*] Installing VIP Tools...${NC}"
    pkg install python git sqlmap nmap php openssh cmatrix -y
    git clone https://github.com/Tuhinshubhra/RED_HAWK $HOME/RED_HAWK 2>/dev/null
}

# =============================================
# MAIN MENU (Everything Intact)
# =============================================
main_menu() {
    show_header
    echo -e "${WHITE}[1] ${CYAN}Full VIP Installation (Theme + Setup)${NC}"
    echo -e "${WHITE}[2] ${CYAN}Update & Optimize Termux${NC}"
    echo -e "${WHITE}[3] ${CYAN}Install TechXtra Hacking Tools${NC}"
    echo -e "${WHITE}[4] ${CYAN}Repair Corrupt Packages${NC}"
    echo -e "${WHITE}[5] ${GREEN}Run Matrix Animation Loop (10s)${NC}"
    echo -e "${WHITE}[6] ${RED}Exit${NC}"
    echo ""
    read -p "Select an option: " choice

    case $choice in
        1) # Theme Engine Logic call
           pkg install fish starship cmatrix -y
           chsh -s fish ;;
        2) optimize_system ;;
        3) install_tools ;;
        4) pkg install --fix-broken -y ;;
        5) start_matrix_loop ;;
        6) exit 0 ;;
        *) main_menu ;;
    esac
}

main_menu
